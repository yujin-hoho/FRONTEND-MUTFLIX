{
  "regions": ["iad1"],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://melancholia112-mutflix.hf.space/api/:path*"
    },
    {
      "source": "/subtitle/:path*",
      "destination": "https://melancholia112-mutflix.hf.space/subtitle/:path*"
    },
    {
      "source": "/gdrive-proxy/:path*",
      "destination": "https://melancholia112-mutflix.hf.space/gdrive-proxy/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}